{
	"$schema": "https://json.schemastore.org/package",
	"name": "lasernex",
	"version": "0.1.0",
	"license": "AGPL-3.0-only",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev --turbo",
		"build": "next build",
		"start": "next start",
		"lint": "biome check --write",
		"test": "vitest",
		"prepare": "husky",
		"docker:build": "docker build -t yournextstore .",
		"docker:run": "docker run -d -p 3000:3000 yournextstore"
	},
	"dependencies": {
		"@radix-ui/react-checkbox": "1.3.8",
		"@radix-ui/react-collapsible": "1.1.17",
		"@radix-ui/react-dialog": "1.1.20",
		"@radix-ui/react-dropdown-menu": "2.1.21",
		"@radix-ui/react-icons": "1.3.2",
		"@radix-ui/react-label": "2.1.12",
		"@radix-ui/react-navigation-menu": "1.2.19",
		"@radix-ui/react-popover": "1.1.20",
		"@radix-ui/react-radio-group": "1.4.4",
		"@radix-ui/react-select": "2.3.4",
		"@radix-ui/react-separator": "1.1.12",
		"@radix-ui/react-slot": "1.3.0",
		"@radix-ui/react-tabs": "1.1.18",
		"@radix-ui/react-toggle": "1.1.15",
		"@radix-ui/react-toggle-group": "1.1.16",
		"@radix-ui/react-tooltip": "1.2.13",
		"@react-email/components": "1.0.12",
		"@splinetool/react-spline": "4.1.0",
		"@splinetool/runtime": "1.12.98",
		"@stripe/react-stripe-js": "6.8.0",
		"@stripe/stripe-js": "9.12.0",
		"@t3-oss/env-nextjs": "0.13.11",
		"@vercel/analytics": "1.4.1",
		"@vercel/edge-config": "1.4.3",
		"@vercel/speed-insights": "1.1.0",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"cmdk": "1.1.1",
		"commerce-kit": "0.54.0",
		"intl-messageformat": "10.7.14",
		"jose": "5.9.6",
		"lucide-react": "0.474.0",
		"ms": "^2.1.3",
		"nanoid": "5.0.9",
		"next": "16.2.10",
		"next-themes": "0.4.6",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-markdown": "10.1.0",
		"resend": "6.17.2",
		"schema-dts": "1.1.2",
		"server-only": "0.0.1",
		"sonner": "1.7.2",
		"stripe": "22.3.2",
		"tailwind-merge": "2.6.0",
		"tailwindcss-animate": "1.0.7",
		"vaul": "1.1.2",
		"zod": "3.24.1"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@commitlint/cli": "19.6.1",
		"@commitlint/config-conventional": "19.6.0",
		"@commitlint/types": "19.5.0",
		"@next/env": "16.2.10",
		"@semantic-release/changelog": "6.0.3",
		"@semantic-release/commit-analyzer": "13.0.1",
		"@semantic-release/git": "10.0.1",
		"@semantic-release/github": "11.0.1",
		"@semantic-release/npm": "12.0.1",
		"@semantic-release/release-notes-generator": "14.1.1",
		"@tailwindcss/forms": "0.5.11",
		"@tailwindcss/postcss": "4.3.3",
		"@tailwindcss/typography": "0.5.20",
		"@testing-library/jest-dom": "6.6.3",
		"@testing-library/react": "16.3.2",
		"@types/node": "22.20.1",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "4.3.4",
		"babel-plugin-react-compiler": "1.0.0",
		"husky": "9.1.7",
		"lint-staged": "15.4.2",
		"postcss": "8.5.20",
		"semantic-release": "24.2.1",
		"sharp": "0.35.3",
		"tailwindcss": "4.3.3",
		"tsx": "4.23.1",
		"typescript": "5.9.3",
		"vite-tsconfig-paths": "5.1.4",
		"vitest": "3.0.4"
	},
	"pnpm": {
		"overrides": {
			"@types/node": "^20 || ^22",
			"trim-newlines@<3.0.1": ">=3.0.1"
		},
		"peerDependencyRules": {
			"allowedVersions": {
				"next": "15.1.1-canary.2",
				"react": "^19.0.0",
				"react-dom": "^19.0.0",
				"@stripe/stripe-js": ">=5.0.0"
			},
			"allowAny": ["@types/react", "@types/react-dom"]
		}
	},
	"engines": {
		"node": ">=20.9.0",
		"bun": "^1.2.0"
	},
	"packageManager": "bun@1.3.14",
	"release": {
		"branches": ["main"],
		"plugins": [
			"@semantic-release/commit-analyzer",
			"@semantic-release/release-notes-generator",
			"@semantic-release/changelog",
			"@semantic-release/npm",
			"@semantic-release/git",
			"@semantic-release/github"
		]
	},
	"lint-staged": {
		"*": ["bun run biome check --write --staged --no-errors-on-unmatched --files-ignore-unknown=true"]
	},
	"patchedDependencies": {
		"commerce-kit@0.0.39": "patches/commerce-kit@0.0.39.patch"
	}
}
