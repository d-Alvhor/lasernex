# Lasernex — variables de entorno
# Copia este fichero a .env.local (nunca subas .env.local al repo)

# URL pública del sitio (local: http://localhost:3000 · producción: https://lasernex.es)
NEXT_PUBLIC_URL=http://localhost:3000

# Stripe — modo test en desarrollo (sk_test_/pk_test_), modo live solo en producción (Fase 4)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=eur
ENABLE_STRIPE_TAX=

# Idioma de la tienda
NEXT_PUBLIC_LANGUAGE=es-ES

# Resend — emails de marca (confirmación de pedido, envío). Sin esta clave
# los emails simplemente no se envían (se avisa por consola), no rompe nada.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Lasernex <pedidos@lasernex.es>"

# Secreto para el enlace de "marcar pedido como enviado" (OPERATIONS.md).
# Genera uno fuerte con: openssl rand -hex 32
SHIP_NOTIFICATION_SECRET=

# Docker (opcional, solo si se despliega fuera de Vercel)
DOCKER=

# OPCIONAL — analítica sin cookies (Umami)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
